STACKFORGE_ENV=production
STACKFORGE_HTTP_ADDR=:8080
STACKFORGE_STATE_DIR=/var/lib/stackforge
STACKFORGE_LOG_LEVEL=info
STACKFORGE_ADMIN_API_KEYS=
STACKFORGE_RECONCILER_ENABLED=true
STACKFORGE_RECONCILER_INTERVAL_SECONDS=300
STACKFORGE_READY_PROTECTED=true

DATABASE_URL=

CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_DEFAULT_ZONE_ID=

NOMAD_ADDR=
NOMAD_TOKEN=
NOMAD_NAMESPACE=
NOMAD_REGION=

CONSUL_HTTP_ADDR=
CONSUL_HTTP_TOKEN=
CONSUL_DATACENTER=

TRAEFIK_CERT_RESOLVER=letsencrypt
TRAEFIK_ENTRYPOINT=websecure

ALLOW_WILDCARD_DOMAINS=false
